    {
      "id": "mobile-deeplink-testing",
      "title": "Deep Link Testing",
      "category": "Mobile",
      "phase": "Exploitation",
      "severity": "High",
      "tags": ["android", "deeplink", "intent", "auth-bypass"],
      "file": "content/notes/mobile-deeplink-testing.md",
      "commands": [
        "adb shell am start -W -a android.intent.action.VIEW -d '<URL>' <PACKAGE>",
        "adb shell dumpsys package <PACKAGE> | grep -iE 'scheme|host|intent'",
        "grep -Rni 'android:scheme\\|android:host\\|intent-filter' output/apktool"
      ],
      "checklist": [
        "Extract schemes, hosts, and paths",
        "Launch each deep link with controlled parameters",
        "Check authentication and authorization gates",
        "Test unsafe redirects or token leakage",
        "Document activity, URI, and expected role"
      ],
      "next": ["mobile-apk-static-analysis"],
      "references": [
        { "label": "Android App Links", "url": "https://developer.android.com/training/app-links" }
      ]
    },
