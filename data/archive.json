      "tags": ["android", "apk", "static-analysis", "secrets"],
      "file": "content/notes/mobile-apk-static-analysis.md",
      "commands": [
        "apktool d <FILE> -o output/apktool",
        "jadx -d output/jadx <FILE>",
        "grep -RniE 'api[_-]?key|secret|token|password|firebase' output/"
      ],
      "checklist": [
        "Confirm app build and package name",
        "Decompile APK resources and code",
        "Search for secrets and endpoints",
        "Review manifest permissions and exported components",
        "Link findings to dynamic testing notes"
      ],
      "next": ["mobile-deeplink-testing"],
      "references": [
        { "label": "OWASP MASTG", "url": "https://mas.owasp.org/MASTG/" }
