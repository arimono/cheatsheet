    {
      "id": "xss-testing",
      "title": "XSS (Cross-Site Scripting)",
      "category": "Web",
      "phase": "Exploitation",
      "severity": "High",
      "tags": ["xss", "injection", "client-side", "A03:2021"],
      "file": "content/notes/xss-testing.md",
      "commands": [
        "dalfox url '<URL>/page?q=test' --blind '<URL>/callback'",
        "grep -R \"innerHTML\\|document.write\" ./src"
      ],
      "checklist": [
        "Identify reflected or stored input",
        "Test encoding context",
        "Confirm exploitability with harmless payload",
        "Record browser and account role"
      ],
      "next": ["sql-injection-testing"],
      "references": [
        { "label": "OWASP XSS", "url": "https://owasp.org/www-community/attacks/xss/" }
