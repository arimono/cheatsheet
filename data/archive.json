    {
      "id": "api-jwt-review",
      "title": "JWT Configuration Review",
      "category": "API",
      "phase": "Enumeration",
      "severity": "High",
      "featured": true,
      "tags": ["jwt", "auth", "api", "token"],
      "file": "content/notes/api-jwt-review.md",
      "commands": [
        "curl -i -H \"Authorization: Bearer <TOKEN>\" <URL>/api/me",
        "python3 jwt_tool.py <TOKEN> -C -d <WORDLIST>",
        "jq -R 'split(\".\") | .[0],.[1] | @base64d | fromjson' token.txt"
      ],
      "checklist": [
        "Collect a valid in-scope token",
        "Decode header and claims",
        "Check algorithm and key handling",
        "Test expiration, audience, and issuer validation",
        "Document accepted malformed or expired tokens"
      ],
      "next": ["api-rate-limit-testing"],
      "references": [
        { "label": "OWASP API Security Top 10", "url": "https://owasp.org/API-Security/" },
        { "label": "JWT Tool", "url": "https://github.com/ticarpi/jwt_tool" }
      ]
    },
    {
      "id": "api-rate-limit-testing",
      "title": "API Rate Limit Testing",
      "category": "API",
      "phase": "Exploitation",
      "severity": "Medium",
      "tags": ["rate-limit", "bruteforce", "api", "abuse-case"],
      "file": "content/notes/api-rate-limit-testing.md",
      "commands": [
        "ffuf -w <WORDLIST> -u <URL>/api/login -X POST -H 'Content-Type: application/json' -d '{\"username\":\"<USER>\",\"password\":\"FUZZ\"}'",
        "seq 1 50 | xargs -I{} curl -s -o /dev/null -w '%{http_code}\\n' <URL>/api/me"
      ],
      "checklist": [
        "Confirm rate-limit testing is permitted",
        "Identify login, OTP, reset, or expensive endpoints",
        "Measure baseline response codes and lockout behavior",
        "Test account, IP, token, and endpoint level limits",
        "Record request count, time window, and impact"
      ],
      "next": ["api-jwt-review"],
      "references": [
        { "label": "OWASP API4 Unrestricted Resource Consumption", "url": "https://owasp.org/API-Security/editions/2023/en/0xa4-unrestricted-resource-consumption/" }
      ]
    },
    {
      "id": "mobile-apk-static-analysis",
      "title": "APK Static Analysis",
      "category": "Mobile",
      "phase": "Reconnaissance",
      "severity": "Info",
